# Template — safe to commit. Copy to .env and fill in real values.
# Get the TURN values from: dash.cloudflare.com -> Realtime -> TURN Server

# Server (signaling) — server-side secrets, never shipped to the browser
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_KEY_SECRET=

# Server port (Render injects this automatically in production)
PORT=8080

# Optional: debug | info | warn | error  (default: info)
# LOG_LEVEL=info

# Client (build-time) — set to the deployed signaling server's wss:// URL.
# In local dev this is unset and defaults to ws://<host>:8080.
# VITE_SIGNALING_URL=wss://your-service.onrender.com
